<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base App Theme -->
    <style name="Theme.SalonBook" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryDark">@color/purple_primary_dark</item>
        <item name="colorSecondary">@color/purple_secondary</item>
        <item name="colorOnPrimary">@color/accent_white</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background_light</item>
        <item name="android:statusBarColor">@color/purple_primary_dark</item>
        <item name="android:navigationBarColor">@color/accent_white</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.SalonBook.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/purple_primary_dark</item>
        <item name="android:navigationBarColor">@color/purple_primary</item>
    </style>

    <!-- Toolbar Style -->
    <style name="SalonBook.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/purple_primary</item>
        <item name="titleTextColor">@color/accent_white</item>
        <item name="subtitleTextColor">@color/accent_white</item>
    </style>

    <!-- Primary Button -->
    <style name="SalonBook.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="android:textColor">@color/accent_white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Outlined Button -->
    <style name="SalonBook.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/purple_primary</item>
        <item name="android:textColor">@color/purple_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Card Style -->
    <style name="SalonBook.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">16dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
    </style>

    <!-- TextInputLayout Style -->
    <style name="SalonBook.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/purple_primary</item>
        <item name="hintTextColor">@color/purple_primary</item>
    </style>

    <!-- Chip Style -->
    <style name="SalonBook.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_category</item>
        <item name="android:textColor">@color/chip_category_text</item>
        <item name="chipCornerRadius">20dp</item>
    </style>

    <!-- Time Slot Chip -->
    <style name="SalonBook.Chip.TimeSlot" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipStrokeColor">@color/purple_primary</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="SalonBook.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/accent_white</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/SalonBook.BottomNav.ActiveIndicator</item>
    </style>

    <style name="SalonBook.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/chip_category</item>
    </style>

    <!-- FAB Style -->
    <style name="SalonBook.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="tint">@color/accent_white</item>
    </style>

    <!-- Dialog Style -->
    <style name="SalonBook.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/purple_primary</item>
    </style>

    <!-- Base style for dot-notation parenting -->
    <style name="SalonBook" parent="" />

    <!-- Base text style for dot-notation parenting -->
    <style name="SalonBook.Text" parent="" />

    <!-- Status Badge Styles -->
    <style name="SalonBook.StatusBadge">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <!-- Heading Text -->
    <style name="SalonBook.Text.Heading">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Subheading Text -->
    <style name="SalonBook.Text.Subheading">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>